<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
  <title>Photo Albums</title>
</head>

<body>
  <header class="site-header">
    <h1>Media Manager</h1>
    <a class="logout-btn header-btn" href="/logout">Logout</a>
  </header>

  <h2>Photo Albums</h2>

  {{#if albums}}
  <ul>
    {{#each albums}}
    <li>
      <a href="/albums/{{name}}">{{name}}</a>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p>No albums found.</p>
  {{/if}}
  
</body>

</html>