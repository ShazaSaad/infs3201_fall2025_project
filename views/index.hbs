<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
  <title>Photo Albums</title>
</head>

<body>
  <header class="site-header">
    <h1>Media Manager</h1>
    <a class="logout-btn header-btn" href="/logout">Logout</a>
  </header>

  <h2>Photo Albums</h2>

  <form action="/search" method="GET" style="margin-top: 20px; width: 320px;">
    <input type="text" name="q" placeholder="Search photos..." required>
    <input type="submit" value="Search">
  </form>


  {{#if albums}}
  <div class="photo-grid">
    {{#each albums}}
    <div class="photo-card">
      <a href="/albums/{{name}}">
        <div class="album-box">
          {{name}}
        </div>
      </a>
    </div>
    {{/each}}
  </div>
  {{else}}
  <p>No albums found.</p>
  {{/if}}

</body>

</html>