<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Photo</title>
</head>

<body>
    <header class="site-header">
        <a class="back-btn header-btn" href="/main">← Back to Albums</a>
        <h1>Media Manager</h1>
        <a class="logout-btn header-btn" href="/logout">Logout</a>
    </header>

    <h2>Photo Details</h2>
    
    {{#if isOwner}}
    <p><a href="/photos/{{photo._id}}/edit">edit</a></p>
    {{/if}}
    <p>Title: {{photo.title}}</p>
    <p>Description:{{photo.description}}</p>
    <p>Visibility:{{photo.visibitlity}}</p>

    <img src="/photos/{{photo.filename}}" alt="{{photo.title}}" onerror="
    const exts = ['.jpg', '.jpeg', '.png']
    const current = this.src
    const nextExt = exts.find(ext => !current.endsWith(ext) && current.includes('/photos/'))
    if (nextExt) {
      const base = current.replace(/\.(jpg|jpeg|png)$/i, '')
      this.onerror = null
      this.src = base + nextExt
    } else {
      this.src = '/photos/default.jpg'
    }
  " />

    <hr>
    <h3>Comments</h3>
    {{#if comments.length}}
    <ul>
        {{#each comments}}
        <li>
            <strong>{{username}}</strong>
            <em style="color:gray;">({{timestamp}})</em><br>
            {{text}}
        </li>
        {{/each}}
    </ul>
    {{else}}
    <p>No comments yet.</p>
    {{/if}}

    <hr>
    <form action="/photos/{{#if photo._id}}{{photo._id}}{{else}}{{photo.id}}{{/if}}/comment" method="POST">
        <label for="text">Comment:</label><br>
        <textarea id="text" name="text" rows="3" cols="40" required></textarea><br><br>
        <button type="submit">Submit Comment</button>
    </form>
  <hr>
    
</body>

</html>