<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Photo</title>
</head>

<body>
    <h1>Photo Details</h1>
    <p><a href="/photos/{{photo._id}}/edit">edit</a></p>
    <p>Title: {{photo.title}}</p>
    <p>Description:{{photo.description}}</p>
    <p>Visibility:{{photo.visibility}}</p>

    <img src="/photos/{{photo.filename}}" onerror="this.src=this.src.replace('.jpg','.jpeg')" alt="{{photo.title}}" />

    <hr>
    <h3>Comments</h3>
    {{#if comments.length}}
    <ul>
        {{#each comments}}
        <li>
            <strong>User {{userID}}</strong>
            <em style="color:gray;">({{date}})</em><br>
            {{text}}
        </li>
        {{/each}}
    </ul>
    {{else}}
    <p>No comments yet.</p>
    {{/if}}

    <hr>
    <form action="/photos/{{photo._id}}/comment" method="POST">
        <label for="userID">userID:</label><br>
        <input type="text" id="userID" name="userID" value="{{photo.owner}}"><br><br>

        <label for="text">Comment:</label><br>
        <textarea id="text" name="text" rows="3" cols="40" required></textarea><br><br>

        <button type="submit">Submit Comment</button>
    </form>
    <p><a href="/">← Back to main page</a></p>
</body>

</html>