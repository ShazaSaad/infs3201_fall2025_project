<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Albums</title>
</head>

<body>
    <header class="site-header">
        <a class="back-btn header-btn" href="/main">← Back to Albums</a>
        <h1>Media Manager</h1>
        <a class="header-btn" href="/notifications">Notifications</a>
        <a class="logout-btn header-btn" href="/logout">Logout</a>
    </header>

    <h2>Photos in {{albumName}} ({{photos.length}} photos)</h2>

    {{#if photos.length}}
    <div class="photo-grid">
        {{#each photos}}
        <div class="photo-card">
            <a href="/photos/{{this._id}}">
                <img src="/photos/{{this.filename}}" alt="{{this.title}}" onerror="
                    const exts = ['.jpg', '.jpeg', '.png']
                    const current = this.src
                    const nextExt = exts.find(ext => !current.endsWith(ext) && current.includes('/photos/'))
                    if (nextExt) {
                    const base = current.replace(/\.(jpg|jpeg|png)$/i, '')
                    this.onerror = null
                    this.src = base + nextExt
                    } else {
                    this.src = '/photos/default.jpg'
                    }
                " />
                <p class="photo-name">{{this.title}}</p>
            </a>
        </div>
        {{/each}}
    </div>
    {{else}}
    <p>No photos found in this album.</p>
    {{/if}}
     
    <form action="/albums/:name/upload" method="post" enctype="multipart/form-data">
        <h3>Upload new photo to {{albumName}} album</h3><br>

        {{#if error}}
            <div class='error'>{{error}}</div>
        {{/if}}
        {{#if success}}
            <div class="success" >{{success}}</div>
        {{/if}}
        <input type="file" name="uploaded_photo" accept=".jpg, .jpeg, .png" id="uploadButton"  required><br>
        <p id="fade">it accepts .jpg .jpeg or .png only!</p>
        <input type="hidden" name="fileName" value=>
        <input type= "hidden" name="userID" value ="">
        <input type="hidden" name="albumName" value={{albumName}}>

     <button >Upload</button>
    </form>
</body>

</html>