<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Edit Photo</title>
</head>
<body>
    <h1>Editing Photo</h1>
    <form action="/photos/{{photo._id}}/edit" method="POST">
        <p>
            <label for="title">Title:</label>
            <input type="text" id="title" name="title" value="{{photo.title}}" required>
        </p>
        <p>
            <label for="description">Description:</label>
            <textarea id="description" name="description" required>{{photo.description}}</textarea>
        </p>
         <p>
            <label for="visibility">Visibility:</label>
            <select name="visibility">
                <option value="private">Private</option>
                <option value="public">Public</option>

            </select>
        </p>
        <button type="submit">Submit</button>
    </form>
    <p><a href="/photos/{{photo._id}}">← Back to Photo Details</a></p>
</body>
</html>