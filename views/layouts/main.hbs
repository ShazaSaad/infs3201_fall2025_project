<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landing Page</title>
</head>
<body>
  <h1>Photo Albums</h1>

  {{#if albums}}
    <ul>
      {{#each albums}}
        <li>{{this.name}}</li>
      {{/each}}
    </ul>
  {{else}}
    <p>No albums found.</p>
  {{/if}}
</body>
</html>